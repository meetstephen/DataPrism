# DataPrism secrets template
# --------------------------------------------------------------------------
# Copy this file to ".streamlit/secrets.toml" and fill in your own values.
# NEVER commit the real secrets.toml (it is gitignored).
#
# On Streamlit Community Cloud, paste these same keys into
# App -> Settings -> Secrets instead of using a file.

# --- Google Gemini (optional: enables AI insights & chat) ---
GEMINI_API_KEY = "your-gemini-api-key"

# --- Supabase (optional: enables the Cloud Workspace) ---
# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL = "https://your-project-ref.supabase.co"
# Use the "anon" public API key for client-side use (see SUPABASE_SETUP.md).
SUPABASE_KEY = "your-supabase-anon-key"

# --- Admin (optional: controls who gets the admin role on sign-up) ---
# The first user to sign up with this email address will automatically
# receive the "admin" role. All other users start as "viewer".
ADMIN_EMAIL = "admin@yourcompany.com"
